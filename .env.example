# Oracle APEX Advanced Solution Environment Variables
# Copy this file to .env and configure with your values

# Application
APP_NAME=oracle-apex-solution
APP_ENV=development
LOG_LEVEL=info

# Database
DB_HOST=localhost
DB_PORT=1521
DB_SERVICE=ORCLPDB1
DB_USER=APEX_SOLUTION
DB_PASSWORD=change_me_in_production

# Oracle APEX
APEX_ADMIN_PASSWORD=change_me_in_production
APEX_WORKSPACE=INTERNAL
APEX_ADMIN=admin

# Docker
ORACLE_DB_VERSION=19.3.0
ORACLE_HTTP_PORT=8080
ORACLE_DB_PORT=1521
